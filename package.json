{
  "name": "emot-id",
  "private": true,
  "version": "0.1.0",
  "description": "Emotion identification system",
  "license": "MIT",
  "engines": {
    "node": ">=18.2.0",
    "npm": ">=9.0.0"
  },
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "dev": "vite --host",
    "type-check": "tsc -b",
    "type-check:watch": "tsc -b -w",
    "build": "npm run type-check && vite build",
    "lint": "eslint . --max-warnings 0",
    "lint:all": "npm run lint && npm run type-check",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:fix": "eslint . --fix",
    "format": "npm run lint:fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check-keys": "node ./check_i18n_keys.cjs",
    "check-translations": "node ./check_translations.cjs",
    "check-untranslated": "node ./check_i18n_untranslated.cjs",
    "i18n-audit": "npm run check-keys && npm run check-translations && npm run check-untranslated",
    "check": "npm run lint && npm run test && npm run i18n-audit && npm run build"
  },
  "dependencies": {
    "framer-motion": "^12.29.2",
    "idb-keyval": "^6.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
}